<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/primary_black"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/home_bg_button_circle"
                android:contentDescription="@string/menu_button"
                android:scaleType="centerInside"
                android:src="@drawable/home_ic_menu_more" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/home_bg_button_circle"
                android:contentDescription="@string/more_button"
                android:scaleType="centerInside"
                android:src="@drawable/home_icon_more" />
        </LinearLayout>

        <TextView
            android:id="@+id/headerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="@string/menu_welcome"
            android:textColor="@color/text_white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/contentFragmentContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintBottom_toTopOf="@id/dockContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerText" />

        <androidx.cardview.widget.CardView
            android:id="@+id/dockContainer"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/dockLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:id="@+id/dockIcon1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/dock_icon_1"
                    android:scaleType="centerInside"
                    android:src="@drawable/home_ic_alarm"
                    app:tint="@color/text_white" />

                <ImageView
                    android:id="@+id/dockIcon2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/dock_icon_2"
                    android:scaleType="centerInside"
                    android:src="@drawable/home_ic_search"
                    app:tint="@color/text_white" />

                <ImageView
                    android:id="@+id/dockIcon3"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/dock_icon_3"
                    android:scaleType="centerInside"
                    android:src="@drawable/home_ic_home"
                    app:tint="@color/text_white" />

                <ImageView
                    android:id="@+id/dockIcon4"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/dock_icon_4"
                    android:scaleType="centerInside"
                    android:src="@drawable/home_ic_calendar"
                    app:tint="@color/text_white" />

                <ImageView
                    android:id="@+id/dockIcon5"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/dock_icon_5"
                    android:scaleType="centerInside"
                    android:src="@drawable/home_ic_event"
                    app:tint="@color/text_white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/fab_button"
            android:src="@drawable/home_ic_add"
            app:backgroundTint="@color/fab_orange"
            app:borderWidth="0dp"
            app:elevation="8dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toTopOf="@id/dockContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/text_white" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/drawerMenu"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/background_dark">

        <include layout="@layout/menu_home" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>


















