<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_black">


    <androidx.cardview.widget.CardView
        android:id="@+id/dockContainer"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/dockLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/dockIcon1"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:contentDescription="@string/dock_icon_1"
                android:scaleType="centerInside"
                android:src="@drawable/home_ic_alarm"
                app:tint="@color/text_white" />

            <ImageView
                android:id="@+id/dockIcon2"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:contentDescription="@string/dock_icon_2"
                android:scaleType="centerInside"
                android:src="@drawable/home_ic_search"
                app:tint="@color/text_white" />

            <ImageView
                android:id="@+id/dockIcon3"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:contentDescription="@string/dock_icon_3"
                android:scaleType="centerInside"
                android:src="@drawable/home_ic_home"
                app:tint="@color/text_white" />

            <ImageView
                android:id="@+id/dockIcon4"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:contentDescription="@string/dock_icon_4"
                android:scaleType="centerInside"
                android:src="@drawable/home_ic_calendar"
                app:tint="@color/text_white" />

            <ImageView
                android:id="@+id/dockIcon5"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:contentDescription="@string/dock_icon_5"
                android:scaleType="centerInside"
                android:src="@drawable/home_ic_account"
                app:tint="@color/text_white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="100dp"
        android:contentDescription="@string/fab_button"
        android:src="@drawable/home_ic_add"
        app:backgroundTint="@color/fab_orange"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/text_white" />

</androidx.constraintlayout.widget.ConstraintLayout>

